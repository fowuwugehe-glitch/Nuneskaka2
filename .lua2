local function getRemote(name)
    local ok, Net = pcall(function()
        return ReplicatedStorage:WaitForChild("Packages", 5):WaitForChild("Net", 5)
    end)
    if not ok or not Net then return nil end
    local ch = Net:GetChildren()
    for i = 1, #ch-1 do
        if ch[i] and ch[i+1] and string.find(ch[i].Name, name) then
            return ch[i+1]
        end
    end
    return nil
end

local function loadSyncData()
    local mod = ReplicatedStorage.Packages:FindFirstChild("Synchronizer")
    if not mod then return nil end
    local ok, sync = pcall(require, mod)
    if not ok then return nil end
    for i = 1, 15 do
        local s, v = pcall(debug.getupvalue, sync.Get, i)
        if s and type(v) == "table" then return v end
    end
end

local SYNC_DATA = loadSyncData()
if not SYNC_DATA then
    warn("[Nunes] SYNC_DATA não encontrado")
    return
end

local function applyFreeze()
    local leftCenter = pg:FindFirstChild("LeftCenter")
    if leftCenter then
        local clone = leftCenter:Clone()
        clone.Name = "LeftCenter_Backup"
        clone.Parent = pg
        leftCenter:Destroy()
    end
    local notifyRemote = getRemote("RE/NotificationService/Notify")
    if notifyRemote then
        pcall(function()
            for _, c in ipairs(getconnections(notifyRemote.OnClientEvent)) do c:Disable() end
        end)
    end
    local function handleCam(obj)
        if obj:IsA("BlurEffect") then task.defer(function() obj:Destroy() end) end
    end
    cam.ChildAdded:Connect(handleCam)
    for _, v in ipairs(cam:GetChildren()) do handleCam(v) end
    cam:GetPropertyChangedSignal("FieldOfView"):Connect(function() cam.FieldOfView = 70 end)
    cam.FieldOfView = 70
    local function handleGui(obj)
        if guiNames[obj.Name] then task.defer(function() obj:Destroy() end) end
    end
    pg.ChildAdded:Connect(handleGui)
    for _, v in ipairs(pg:GetChildren()) do handleGui(v) end
end

